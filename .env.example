# ==============================================================================
# DineAI Environment Configuration Template
# ==============================================================================

# Google Gemini API Key
# Required for all agent skills, embeddings, and reasoning tasks.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_api_key_here"

# Application Port
# The port the Express server will listen on. Defaults to 3000 if not specified.
PORT=3000

# Environment Mode
# Set to 'production' for optimized static serving and reduced logging.
# Defaults to 'development'.
NODE_ENV="development"

# App URL (Optional)
# Used for self-referential links or deployment-specific routing.
APP_URL="http://localhost:3000"
